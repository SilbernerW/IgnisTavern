{
  "name": "ignis-tavern-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check:consistency": "node scripts/check-consistency.js",
    "setup:hooks": "node scripts/install-hooks.js",
    "sync": "node scripts/sync-skill.js && npm run check:consistency",
    "dev": "npm run sync && next dev",
    "build": "npm run sync && next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next/** --ignore-pattern node_modules/** --ignore-pattern next-env.d.ts",
    "lint:next": "next lint"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "next": "15.x",
    "react": "19.x",
    "react-dom": "19.x",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.38.0",
    "eslint-config-next": "^15.5.5",
    "typescript": "^5"
  }
}
